# Flask config
SECRET_KEY=super-secret-key-change-this-in-production
FLASK_APP=app.py
FLASK_ENV=development
PORT=5000

# Database Configuration
# Default is SQLite for easy local setup:
DATABASE_URL=sqlite:///crop_recommender.db

# To use MySQL instead, uncomment and configure below (requires SQLAlchemy & PyMySQL):
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/crop_recommender
